# Landing Page Factory — Environment Variables

# Firecrawl API key (strongly recommended for public-release-quality extraction)
# Get yours at https://firecrawl.dev
# FIRECRAWL_API_KEY=your_key_here

# Bloom API key (optional, recommended for first-pass image generation)
# Get yours at https://go.trybloom.ai/matthew-berman
# BLOOM_API_KEY=your_key_here

# Recommended image provider order
# IMAGE_PROVIDER=bloom
# IMAGE_FALLBACK_PROVIDER=nano-banana

# Optional external command for Nano Banana fallback.
# The command should accept the job JSON path as its final argument
# and print a JSON result object to stdout.
# NANO_BANANA_COMMAND="/path/to/your/nano-banana-adapter"
